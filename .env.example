# .env 템플릿 — 실제 .env로 복사 후 사내 환경값으로 채우세요.

# 사내 모델 레지스트리 경로 (마운트된 디렉토리)
EMBEDDER_PATH=models/bge-m3
RERANKER_PATH=models/bge-reranker-v2-m3

# ChromaDB 영속화 경로 (배포 환경의 영속 볼륨)
CHROMA_PERSIST_DIR=data/chroma

# 인덱싱
HISTORY_MONTHS=12
DEDUP_THRESHOLD=0.95
EMBED_BATCH_SIZE=32

# 검색
TOP_K_OFFICIAL=5
TOP_K_HISTORY=15
RERANK_TOP_K=10
FINAL_TOP_K=3
RRF_K=60
ANSWER_THRESHOLD=0.5

# LLM 종합
SYNTHESIS_TOP_K=3

# 부서 라우팅
DEPARTMENTS_YAML=app/routing/departments.yaml

# 엑셀 컬럼명 (config.py 기본값에 이미 한국어 매핑됨, 다른 이름 쓰면 덮어쓰기)
COL_QUESTION=인수심사FAQ내용
COL_ANSWER=인수심사답변내용
COL_ANSWERED_AT=수정일시
COL_REF_NO=인수톡FAQ일련번호