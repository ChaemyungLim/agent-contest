# .env 템플릿 — 실제 .env로 복사 후 사내 환경값으로 채우세요.

# 사내 모델 레지스트리 경로 (마운트된 디렉토리)
EMBEDDER_PATH=models/bge-m3
RERANKER_PATH=models/bge-reranker-v2-m3

# ChromaDB 영속화 경로 (배포 환경의 영속 볼륨)
CHROMA_PERSIST_DIR=data/chroma

# 인덱싱
HISTORY_MONTHS=12
DEDUP_THRESHOLD=0.95
EMBED_BATCH_SIZE=32

# 검색
TOP_K_OFFICIAL=5
TOP_K_HISTORY=15
RERANK_TOP_K=20
FINAL_TOP_K=3
RRF_K=60
OFFICIAL_BOOST=0.05
ANSWER_THRESHOLD=0.5

# LLM 종합
SYNTHESIS_TOP_K=3

# 부서 라우팅
DEPARTMENTS_YAML=app/routing/departments.yaml

# 엑셀 컬럼명 (입력 파일이 다른 컬럼명을 쓰면 덮어쓰기)
COL_QUESTION=question
COL_ANSWER=answer
COL_ANSWERED_AT=answered_at
COL_ANSWERED_BY=answered_by